{
    "name": "zairigimad/ux-haptics",
    "description": "Symfony UX bundle for haptic feedback on the mobile web using web-haptics",
    "keywords": ["symfony-ux", "haptics", "vibration", "web-haptics", "stimulus"],
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": ">=8.2",
        "symfony/dependency-injection": "^7.0 || ^8.0",
        "symfony/http-kernel": "^7.0 || ^8.0"
    },
    "require-dev": {
        "symfony/asset-mapper": "^7.0 || ^8.0",
        "symfony/framework-bundle": "^7.0 || ^8.0",
        "symfony/twig-bundle": "^7.0 || ^8.0",
        "symfony/stimulus-bundle": "^2.9",
        "twig/twig": "^3.0",
        "phpunit/phpunit": "^9.6",
        "symfony/phpunit-bridge": "^7.0 || ^8.0",
        "php-cs-fixer/shim": "^3.94",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Zairigimad\\UxHaptics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zairigimad\\UxHaptics\\Tests\\": "tests/"
        }
    },
    "extra": {
        "thanks": {
            "name": "zairigimad/ux-haptics",
            "url": "https://github.com/zairigimad/ux-haptics"
        }
    }
}
